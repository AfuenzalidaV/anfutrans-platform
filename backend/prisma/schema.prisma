generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model cargo_dirigencial {
  id     Int      @id @default(autoincrement()) @db.SmallInt
  codigo String   @unique @db.VarChar(50)
  nombre String   @db.VarChar(100)
  nivel  String?  @db.VarChar(20)
  activo Boolean? @default(true)
}

model comuna {
  id        Int      @id @default(autoincrement())
  region_id Int      @db.SmallInt
  codigo    String   @unique @db.VarChar(10)
  nombre    String   @db.VarChar(100)
  activo    Boolean? @default(true)
  region    region   @relation(fields: [region_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model estado_solicitud {
  id     Int      @id @default(autoincrement()) @db.SmallInt
  codigo String   @unique @db.VarChar(50)
  nombre String   @db.VarChar(100)
  orden  Int?
  activo Boolean? @default(true)
}

model parametro_sistema {
  id          String    @id @default(dbgenerated("public.uuid_generate_v4()")) @db.Uuid
  clave       String    @unique @db.VarChar(100)
  valor       String?
  descripcion String?
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
}

model region {
  id     Int      @id @default(autoincrement()) @db.SmallInt
  codigo String   @unique @db.VarChar(10)
  nombre String   @db.VarChar(100)
  activo Boolean? @default(true)
  comuna comuna[]
}

model tipo_beneficio {
  id     Int      @id @default(autoincrement()) @db.SmallInt
  codigo String   @unique @db.VarChar(50)
  nombre String   @db.VarChar(100)
  activo Boolean? @default(true)
}

model tipo_certificado {
  id                Int      @id @default(autoincrement()) @db.SmallInt
  codigo            String   @unique @db.VarChar(50)
  nombre            String   @db.VarChar(100)
  requiere_vigencia Boolean? @default(false)
  activo            Boolean? @default(true)
}

model tipo_documento {
  id     Int      @id @default(autoincrement()) @db.SmallInt
  codigo String   @unique @db.VarChar(50)
  nombre String   @db.VarChar(100)
  ambito String?  @db.VarChar(50)
  activo Boolean? @default(true)
}

model tipo_solicitud {
  id                  Int      @id @default(autoincrement()) @db.SmallInt
  codigo              String   @unique @db.VarChar(50)
  nombre              String   @db.VarChar(150)
  descripcion         String?
  requiere_aprobacion Boolean? @default(true)
  permite_borrador    Boolean? @default(false)
  activo              Boolean? @default(true)
}
