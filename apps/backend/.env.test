# ================================
# TESTING
# ================================
NODE_ENV="test"
PORT=3001
API_PREFIX="api"

# Database - Base de datos separada para tests
DATABASE_URL="postgresql://anfutrans_test:test_password@localhost:5432/anfutrans_test?schema=core"

# JWT - Valores simplificados para tests
JWT_SECRET="test-secret-key-not-for-production"
JWT_EXPIRATION="1h"
JWT_REFRESH_SECRET="test-refresh-secret"
JWT_REFRESH_EXPIRATION="2h"

# Bcrypt - Menos rounds para tests más rápidos
BCRYPT_SALT_ROUNDS=4

# CORS
CORS_ORIGIN="http://localhost:4200"

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH="./uploads-test"

# Logging - Menos verbose en tests
LOG_LEVEL="error"
LOG_FORMAT="minimal"

# Swagger - Deshabilitado en tests
SWAGGER_ENABLED="false"
