# ================================
# ANFUTRANS PLATFORM - Backend
# Environment Variables Template
# ================================

# ------------------------------
# DATABASE CONFIGURATION
# ------------------------------
DATABASE_URL="postgresql://anfutrans_app:CambiarPasswordSegura@localhost:5432/anfutrans_db?schema=core"

# Componentes:
# - Usuario: anfutrans_app
# - Password: CambiarPasswordSegura (CAMBIAR EN PRODUCCIÓN)
# - Host: localhost (cambiar en producción)
# - Puerto: 5432
# - Database: anfutrans_db
# - Schema: core

# ------------------------------
# JWT CONFIGURATION
# ------------------------------
JWT_SECRET="CAMBIAR_ESTE_SECRET_POR_UNO_SEGURO_EN_PRODUCCION"
JWT_EXPIRATION="24h"
JWT_REFRESH_SECRET="CAMBIAR_ESTE_REFRESH_SECRET_POR_UNO_SEGURO"
JWT_REFRESH_EXPIRATION="7d"

# ------------------------------
# APPLICATION CONFIGURATION
# ------------------------------
NODE_ENV="development"
PORT=3000
API_PREFIX="api"

# ------------------------------
# CORS CONFIGURATION
# ------------------------------
CORS_ORIGIN="http://localhost:4200"
# En producción, cambiar a dominio real: https://app.anfutrans.cl

# ------------------------------
# FILE UPLOAD CONFIGURATION
# ------------------------------
MAX_FILE_SIZE=10485760
# 10MB en bytes (10 * 1024 * 1024)

UPLOAD_PATH="./uploads"
# Ruta relativa desde apps/backend/

# ------------------------------
# LOGGING
# ------------------------------
LOG_LEVEL="debug"
# Opciones: error, warn, info, debug, verbose

# ------------------------------
# BCRYPT CONFIGURATION
# ------------------------------
BCRYPT_SALT_ROUNDS=10
# Número de rounds para hash de contraseñas

# ------------------------------
# FRONTEND URL (para emails, redirecciones)
# ------------------------------
FRONTEND_URL="http://localhost:4200"
# En producción: https://app.anfutrans.cl

# ------------------------------
# SWAGGER CONFIGURATION
# ------------------------------
SWAGGER_ENABLED=true
SWAGGER_PATH="api"

# ------------------------------
# EMAIL CONFIGURATION (opcional)
# ------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=notificaciones@anfutrans.cl
# SMTP_PASS=password_seguro
# SMTP_FROM="ANFUTRANS <notificaciones@anfutrans.cl>"

# ------------------------------
# REDIS CONFIGURATION (opcional, para caching)
# ------------------------------
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TTL=3600

# ================================
# NOTAS IMPORTANTES
# ================================
#
# 1. NUNCA commitear este archivo con valores reales
# 2. Copiar como .env y cambiar valores según ambiente
# 3. En producción, usar secretos generados aleatoriamente
# 4. JWT_SECRET debe tener al menos 32 caracteres
# 5. Passwords de BD deben ser complejas (min 16 caracteres)
#
# Comando para generar secretos seguros:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
